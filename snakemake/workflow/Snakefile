use rule run_lar_null_in_art_out from basic_lar as gen_cosmics with:
    output:
        "cosmics.root"
    params:
        n=config["n"],
        fcl="prod_cosmics_protodunehd.fcl",
        extra="--no-memcheck --no-timing --no-trace"


use rule run_lar_single_in_art_out from basic_lar as g4 with:
    output:
        "g4_cosmics.root"
    input:
        "cosmics.root"
    params:
        n=1,
        fcl="resources/run_g4_only.fcl",
        extra="--no-memcheck --no-timing --no-trace"

use rule run_lar_single_in_dump_text from basic_lar as dump_g4 with:
    output: "g4_cosmics.txt"
    input:
        "g4_cosmics.root"
    params:
        n="-1",
        fcl="eventdump.fcl",
        extra="--no-memcheck --no-timing --no-trace"

use rule run_lar_single_in_dump_text from basic_lar as dump_gen with:
    output: "cosmics.txt"
    input:
        "cosmics.root"
    params:
        n="-1",
        fcl="eventdump.fcl",
        extra="--no-memcheck --no-timing --no-trace"

rule jgf:
    output:
        "justin_input_files.txt"
    shell:
        """
        touch {output}

        for ((i=0; i < {config[nfiles]}; i++)); do
            echo "Calling justin get file -- $i"
            DID_PFN_RSE=$($JUSTIN_PATH/justin-get-file)
            if [ "$DID_PFN_RSE" == "" ] ; then
                echo "Could not get file. Exiting loop"
                break
            fi
            echo $DID_PFN_RSE >> {output}
            
        done


        """

rule all:
    input:
        "justin_input_files.txt"
    shell:
        """
        echo "Files in {input}:"
        cat {input}
        """