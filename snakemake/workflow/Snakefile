from viper import functions as vf

module control:
    snakefile: "rules/control.smk"

config.setdefault("nfiles", "1")
use rule * from control
use rule jgf from control with:
    params:
        nfiles=config['nfiles']


# This is the user-defined workflow and the main point-of-entry for users.
# Needs to be provided
middle_layer=config["UserWorkflow"]
include: middle_layer

## 'final_stages' is defined in the middle_layer, we extract the output here.
requested = vf.extract_output(
    *final_stages
)

## Depending on justin-get-file behavior, will direct rule 'all'
use rule Processing from control with:
    input: requested
rule all:
    input:
        vf.make_check_jgf(rules, checkpoints)